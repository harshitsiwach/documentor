# Documentor Configuration
# Copy this file to .env and adjust as needed

# Server port
PORT=3000

# Default LLM provider: "ollama" or "lmstudio" or "custom"
LLM_PROVIDER=ollama

# LLM API base URL (no trailing slash)
# Ollama default: http://localhost:11434
# LM Studio default: http://localhost:1234
LLM_BASE_URL=http://localhost:11434

# Default model name (must be available on your LLM server)
LLM_MODEL=llama3

# Default folder to scan for documents
DOCUMENTS_FOLDER=

# Max context tokens to send to LLM (adjust based on your model)
MAX_CONTEXT_TOKENS=8192
